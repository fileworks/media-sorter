{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/fileworks/media-sorter.git",
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to MediaSorter are documented here.\nThis file is generated by semantic-release from [Conventional Commits](https://www.conventionalcommits.org/) — do not edit it by hand."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-version.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "backend/app/_version.py",
          "frontend/package.json",
          "frontend/package-lock.json",
          "frontend/src-tauri/tauri.conf.json",
          "frontend/src-tauri/Cargo.toml",
          "frontend/src-tauri/Cargo.lock"
        ],
        "message": "chore(release): v${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ]
  ]
}
