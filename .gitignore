# ── Release build artefacts (generated by `make release`) ────────────────────
# PyInstaller-frozen backend + static ffmpeg — large binaries, never commit.
# Recreate with: make bundle-backend  and  make bundle-ffmpeg
frontend/src-tauri/resources/backend/
frontend/src-tauri/resources/ffmpeg/
frontend/src-tauri/resources/ffmpeg-win/
# Local CLIP model for offline AI tagging — a few hundred MB; recreate with:
# make bundle-clip
frontend/src-tauri/resources/clip/

# PyInstaller working files (auto-generated; not needed in source control)
backend/mediasort-backend.spec
backend/dist/
backend/build/

